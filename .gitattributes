###############################################################################
# .NET Project .gitattributes
# Optimized for cross-platform .NET development

# 1. Core defaults
# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf
# 2. Source code
# C# source files
*.cs           text diff=csharp
*.csx          text diff=csharp
# F# source files
*.fs           text diff=fsharp
*.fsi          text diff=fsharp
*.fsx          text diff=fsharp
# Visual Basic
*.vb           text diff=vb
# ASP.NET / Blazor
*.cshtml       text diff=html
*.razor        text diff=html
*.aspx         text diff=html
*.ascx         text diff=html
*.master       text diff=html
# 3. Project and solution files
*.sln          text eol=lf
*.csproj       text eol=lf
*.fsproj       text eol=lf
*.vbproj       text eol=lf
*.vcxproj      text eol=lf
*.props        text eol=lf
*.targets      text eol=lf
*.ruleset      text eol=lf
*.filters      text eol=lf
# NuGet
*.nuspec       text
packages.lock.json text -diff
# 4. Configuration and data files
# XML-based config
*.xml          text
*.config       text
*.resx         text
*.settings     text
*.manifest     text
*.xaml         text diff=xml
# JSON / YAML
*.json         text
*.jsonc        text
*.yml          text
*.yaml         text
# Other config
*.ini          text
*.editorconfig text eol=lf
.globalconfig  text eol=lf
*.DotSettings  text
# 5. Documentation and text files
*.md           text diff=markdown
*.txt          text
*.rst          text
LICENSE        text
AUTHORS        text
CHANGELOG      text
CONTRIBUTING   text
# 6. Web assets
*.html         text diff=html
*.htm          text diff=html
*.css          text diff=css
*.scss         text diff=css
*.sass         text diff=css
*.less         text diff=css
*.js           text
*.ts           text
*.jsx          text
*.tsx          text
*.vue          text
*.svg          text
# 7. Scripts
# Windows scripts (keep CRLF)
*.bat          text eol=crlf
*.cmd          text eol=crlf
*.ps1          text eol=crlf
*.psm1         text eol=crlf
*.psd1         text eol=crlf
# Unix scripts (keep LF)
*.sh           text eol=lf
*.bash         text eol=lf
# 8. CI/CD and DevOps
.gitignore     text eol=lf
.gitattributes text eol=lf
.github/**     text eol=lf
Dockerfile     text eol=lf
.dockerignore  text eol=lf
docker-compose.yml text eol=lf
docker-compose.*.yml text eol=lf
*.dockerfile   text eol=lf
Makefile       text eol=lf
# 9. Database and SQL
*.sql          text
*.dacpac       binary
# 10. Binary files (no diff/merge)
# .NET assemblies and debug symbols
*.dll          binary
*.exe          binary
*.pdb          binary
*.mdb          binary
# Native libraries
*.so           binary
*.dylib        binary
*.a            binary
*.lib          binary
# NuGet packages
*.nupkg        binary
*.snupkg       binary
# Archives
*.zip          binary
*.tar          binary
*.gz           binary
*.7z           binary
*.rar          binary
# Images (common formats, not using LFS for a code-focused repo)
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.bmp          binary
*.webp         binary
# Fonts
*.ttf          binary
*.otf          binary
*.woff         binary
*.woff2        binary
*.eot          binary
# Documents
*.pdf          binary
*.docx         binary
*.xlsx         binary
*.pptx         binary
# 11. Generated / lock files (text but no diff noise)
*.Designer.cs  text diff=csharp -merge
*.generated.cs text diff=csharp -merge
**/obj/**      binary -diff linguist-generated
# 12. Export ignore (excluded from archives)
.git*          export-ignore
.vs/           export-ignore
.vscode/       export-ignore
.idea/         export-ignore
*.user         export-ignore
*.suo          export-ignore
tests/Bezoro.UCI.Tests/_Resources/Engine/stockfish/*.exe filter=lfs diff=lfs merge=lfs -text
