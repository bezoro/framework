# =======================================================
# .NET Project .gitignore
# =======================================================

# ============================
# Build Outputs
# ============================

**/bin/
**/obj/
[Oo]ut/
[Bb]uild/
[Bb]uildLogs/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/

# NuGet packages
*.nupkg
*.snupkg
**/packages/
!**/packages/build/

# ============================
# IDE - Visual Studio
# ============================

.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.ncb
*.aps
*.cachefile
*.psess
*.vsp
*.vspx
*.sap
*.e2e

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# ============================
# IDE - JetBrains Rider
# ============================

.idea/
*.sln.iml
_ReSharper.Caches/

# ============================
# IDE - Visual Studio Code
# ============================

.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
*.code-workspace

# ============================
# Testing
# ============================

# Test results
[Tt]est[Rr]esult*/
TestResults/
*.trx
*.coverage
*.coveragexml

# Coverage reports
coverage/
coverage*.json
coverage*.xml
*.lcov
lcov.info

# ============================
# Benchmarks
# ============================

BenchmarkDotNet.Artifacts/

# ============================
# .NET Specific
# ============================

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.tlog
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# MSBuild
*.msbuild

# NuGet restore files
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET scaffolding
ScaffoldingReadMe.txt

# Fakes assemblies
FakesAssemblies/

# .NET publish profiles
*.pubxml
*.publishproj
!**/PublishProfiles/*.pubxml

# ============================
# Tool-specific
# ============================

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Coverlet
coverage.cobertura.xml

# DocFX
_site/
docfx.json.meta

# MiniCover
.minicoverreport/

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# SpecFlow
*.feature.cs
*.feature.xlsx.*

# Stryker
StrykerOutput/

# ============================
# Operating System
# ============================

# Windows
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory

# ============================
# Secrets and Configuration
# ============================

# User secrets
secrets.json
secrets.*.json
appsettings.Development.json
appsettings.Local.json
*.local.json

# Certificates
*.pfx
*.key
*.pem

# ============================
# Project Specific
# ============================

# Claude Code settings
.claude/

# Logs
[Ll]ogs/

# ============================
# End of .NET .gitignore
